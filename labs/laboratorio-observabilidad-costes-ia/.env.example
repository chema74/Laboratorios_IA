# Variables opcionales para la capa LLM de V2.1.
# Dejar vacio GROQ_API_KEY para ejecutar siempre en fallback local determinista.
GROQ_API_KEY=

# Modelo opcional de Groq. Si queda vacio, se usa llama-3.1-8b-instant.
GROQ_MODEL=

# Modo opcional: groq o fallback_local.
# Si esta vacio, intenta Groq solo si hay clave y, si falla, aplica fallback local.
OBSERVABILIDAD_MODO=
