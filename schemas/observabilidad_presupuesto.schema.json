{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["mes", "presupuesto_mensual_eur", "nota"],
  "additionalProperties": false,
  "properties": {
    "mes": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "presupuesto_mensual_eur": { "type": "number", "minimum": 0 },
    "nota": { "type": "string", "minLength": 1 }
  }
}
