{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "consulta", "respuesta_esperada", "criterios_clave", "riesgos", "categoria"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^CASO-[0-9]{3}$" },
      "consulta": { "type": "string", "minLength": 1 },
      "respuesta_esperada": { "type": "string", "minLength": 1 },
      "criterios_clave": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      },
      "riesgos": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      },
      "categoria": { "type": "string", "minLength": 1 }
    }
  }
}
