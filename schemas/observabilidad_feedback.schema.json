{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id_feedback", "caso_uso", "satisfaccion", "comentario"],
    "additionalProperties": false,
    "properties": {
      "id_feedback": { "type": "string", "pattern": "^F-[0-9]{3}$" },
      "caso_uso": { "type": "string", "minLength": 1 },
      "satisfaccion": { "type": "integer", "minimum": 1, "maximum": 5 },
      "comentario": { "type": "string", "minLength": 1 }
    }
  }
}
