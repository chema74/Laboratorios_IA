{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "salida"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^S-[0-9]{3}$" },
      "salida": { "type": "string", "minLength": 1 }
    }
  }
}
