{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id_tarea", "titulo", "descripcion", "caso_uso"],
    "additionalProperties": false,
    "properties": {
      "id_tarea": { "type": "string", "pattern": "^T-[0-9]{3}$" },
      "titulo": { "type": "string", "minLength": 1 },
      "descripcion": { "type": "string", "minLength": 1 },
      "caso_uso": { "type": "string", "minLength": 1 }
    }
  }
}
