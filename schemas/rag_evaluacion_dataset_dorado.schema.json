{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "consulta", "documentos_esperados"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "pattern": "^Q-[0-9]{3}$" },
      "consulta": { "type": "string", "minLength": 1 },
      "documentos_esperados": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "pattern": "^DOC-[0-9]{3}$" }
      }
    }
  }
}
