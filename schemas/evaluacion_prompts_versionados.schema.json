{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["caso_id", "version", "prompt", "respuesta_sintetica"],
    "additionalProperties": false,
    "properties": {
      "caso_id": { "type": "string", "pattern": "^CASO-[0-9]{3}$" },
      "version": { "type": "string", "pattern": "^v[0-9]+$" },
      "prompt": { "type": "string", "minLength": 1 },
      "respuesta_sintetica": { "type": "string", "minLength": 1 }
    }
  }
}
